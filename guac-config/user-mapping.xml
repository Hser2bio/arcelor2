<user-mapping>

    <authorize username="admin" password="admin">

        <connection name="Ubuntu Desktop">
            <protocol>rdp</protocol>

            <param name="hostname">ubuntu-desktop</param>
            <param name="port">3389</param>
            <param name="username">user</param>
            <param name="password">pass123</param>

            <!-- 🔧 CLAVE: evitar problemas TLS/NLA -->
            <param name="security">rdp</param>
            <param name="ignore-cert">true</param>

            <!-- Opcional pero recomendable -->
            <param name="server-layout">es-es-qwerty</param>
            <param name="color-depth">32</param>
        </connection>

    </authorize>

</user-mapping>
